<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1" author="jose.juan">
        <createTable tableName="ingresos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tipo" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="monto" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="paso_simulacion" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_registro" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="jose.juan">
        <createTable tableName="gastos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="concepto" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="monto" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="paso_simulacion" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_registro" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="3" author="jose.juan">
        <createTable tableName="eventos">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tipo_evento" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="paso_simulacion" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_registro" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>